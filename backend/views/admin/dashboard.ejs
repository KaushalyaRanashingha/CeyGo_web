<!DOCTYPE html>
<html class="light" lang="en">

<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex h-screen">

  <!-- SIDEBAR -->
  <%- include("partials/sidebar", { activePage: "dashboard" }) %>

  <!-- MAIN -->
  <div class="flex-1 flex flex-col">

    <!-- HEADER (SAFE) -->
    <%- include("partials/header", { admin: admin }) %>

    <!-- CONTENT -->
    <main class="p-6">

      <!-- WELCOME -->
      <h1 class="text-2xl font-bold">
        Welcome <%= admin.name %> 🚀
      </h1>

      <p class="text-gray-500">Dashboard Overview</p>

      <!-- STATS -->
      <div class="grid grid-cols-4 gap-4 mt-6">

        <% stats.forEach(s => { %>
          <div class="bg-white p-4 rounded shadow">
            <p class="text-gray-500"><%= s.label %></p>
            <h2 class="text-xl font-bold"><%= s.value %></h2>
          </div>
        <% }) %>

      </div>

      <!-- BOOKINGS -->
      <div class="mt-8 bg-white rounded shadow">

        <div class="p-4 font-bold border-b">
          Recent Bookings
        </div>

        <table class="w-full">

          <thead>
            <tr class="bg-gray-100">
              <th class="p-2">ID</th>
              <th>Customer</th>
              <th>Destination</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>

          <tbody>

            <% recentBookings.forEach(b => { %>
              <tr class="border-t">
                <td class="p-2"><%= b.id %></td>
                <td><%= b.customer %></td>
                <td><%= b.destination %></td>
                <td><%= b.amount %></td>
                <td><%= b.status %></td>
              </tr>
            <% }) %>

          </tbody>

        </table>

      </div>

    </main>

  </div>

</div>

</body>
</html>