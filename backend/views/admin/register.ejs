<% const errs = typeof errors !== 'undefined' ? errors : []; %>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title><%= title %></title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap" rel="stylesheet"/>
<style>body{font-family:'Poppins',sans-serif}</style>
</head>
<body class="bg-[#F4F7FB] min-h-screen">
<div class="flex flex-col min-h-screen">

<header class="flex items-center justify-between border-b bg-white px-8 py-4">
  <h2 class="text-2xl font-bold text-orange-600">CeyGo</h2>
</header>

<main class="flex flex-1 items-center justify-center p-6">
  <div class="w-full max-w-4xl bg-white rounded-2xl shadow-lg overflow-hidden flex">

    <!-- LEFT PANEL -->
    <div class="hidden md:flex w-1/3 bg-blue-900 text-white p-10 flex-col justify-between relative overflow-hidden">
      <div>
        <h2 class="text-3xl font-bold mb-4">Grow your business</h2>
        <p class="text-sm opacity-90">Join thousands of partners using CeyGo.</p>
      </div>
      <div class="relative z-10 mt-10 flex flex-col gap-4">
        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-xl">verified</span><span class="text-xs font-medium">Verified Platform</span></div>
        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-xl">payments</span><span class="text-xs font-medium">Secure Payments</span></div>
        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-xl">support_agent</span><span class="text-xs font-medium">24/7 Partner Support</span></div>
      </div>
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute -right-20 -bottom-20 w-64 h-64 rounded-full border-[20px] border-white"></div>
        <div class="absolute -left-10 top-20 w-32 h-32 rounded-full border-[10px] border-white"></div>
      </div>
    </div>

    <!-- FORM -->
    <div class="flex-1 p-10">
      <h2 class="text-2xl font-bold mb-2">Partner Registration</h2>
      <p class="text-gray-500 mb-6 text-sm">Create your partner account</p>

      <% if (errs.length > 0) { %>
      <div class="mb-6 bg-red-100 border border-red-300 text-red-700 p-4 rounded">
        <ul>
          <% errs.forEach(function(err){ %>
          <li>• <%= err %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form action="<%= action %>" method="POST" enctype="multipart/form-data" class="space-y-5">

        <!-- NAME + EMAIL -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">person</span>
            <input type="text" name="name" value="<%= name || '' %>" placeholder="Full Name" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">mail</span>
            <input type="email" name="email" value="<%= email || '' %>" placeholder="Email Address" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
        </div>

        <!-- PHONE + ID -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">call</span>
            <input type="text" name="phone" value="<%= phone || '' %>" placeholder="Phone Number" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">badge</span>
            <input type="text" name="IdNumber" value="<%= IdNumber || '' %>" placeholder="National ID / Passport" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
        </div>

        <!-- ROLE -->
        <div class="relative">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">category</span>
          <select name="role" class="w-full border rounded-lg p-3 pl-10">
            <option value="">Select Business Type</option>
            <% roles.forEach(function(r){ %>
            <option value="<%= r.value %>" <%= selectedRole===r.value?'selected':'' %>><%= r.label %></option>
            <% }) %>
          </select>
        </div>

        <!-- BUSINESS -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">store</span>
            <input type="text" name="businessname" value="<%= businessname || '' %>" placeholder="Business Name" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">location_on</span>
            <input type="text" name="address" value="<%= address || '' %>" placeholder="Business Location" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
        </div>

        <!-- PASSWORD -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">lock</span>
            <input type="password" name="password" placeholder="Password" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">lock_reset</span>
            <input type="password" name="confirmPassword" placeholder="Confirm Password" class="w-full border rounded-lg p-3 pl-10"/>
          </div>
        </div>

        <!-- FILES -->
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="text-sm font-semibold">Business License</label>
            <input type="file" name="businessLicenseImage" class="w-full border rounded-lg p-2 mt-1"/>
          </div>
          <div>
            <label class="text-sm font-semibold">Profile Image</label>
            <input type="file" name="profileImage" class="w-full border rounded-lg p-2 mt-1"/>
          </div>
        </div>

        <button type="submit" class="w-full bg-blue-900 text-white p-3 rounded-lg font-bold hover:bg-blue-700 flex items-center justify-center gap-2">
          <span>Register Account</span>
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>

        <p class="text-center text-sm text-gray-500">
          Already have account?
          <a href="/login" class="text-blue-900 font-semibold">Login</a>
        </p>
      </form>
    </div>
  </div>
</main>

<footer class="text-center text-xs text-gray-500 py-6">© 2026 CeyGo Travel Platform</footer>
</div>
</body>
</html>