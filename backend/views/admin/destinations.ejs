<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>CeyGo Admin - Destination Management</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#0B1E3D",
            accent: "#FF7A00",
            "background-light": "#F4F7FB",
            "background-dark": "#1a1a1a",
          },
          fontFamily: {
            display: ["Poppins", "Public Sans", "sans-serif"]
          },
        },
      },
    }
  </script>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings:
      'FILL' 0,
      'wght' 400,
      'GRAD' 0,
      'opsz' 24;
    }
  </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100">

<div class="flex h-screen overflow-hidden">

  <!-- Sidebar -->
  <%- include("partials/sidebar", { activePage: "destinations" }) %>

  <!-- Main Area -->
  <div class="flex-1 flex flex-col overflow-hidden">

    <!-- Header -->
    <%- include("partials/header", { admin: admin }) %>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8">

      <!-- Top Section -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">

        <div>
          <h2 class="text-3xl font-bold text-primary dark:text-white">
            Destination Management
          </h2>

          <p class="text-slate-500 text-sm mt-1">
            Manage all travel destinations in the system
          </p>
        </div>

        <a
          href="/admin/destinations/add"
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-orange-600 text-white px-5 py-3 rounded-xl font-semibold shadow-lg shadow-orange-500/20 transition-all"
        >
          <span class="material-symbols-outlined">add</span>
          Add Destination
        </a>

      </div>

      <!-- Search -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-5 mb-6 shadow-sm">

        <form action="/admin/destinations" method="GET">

          <div class="relative">

            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
              search
            </span>

            <input
              type="text"
              name="search"
              value="<%= search || '' %>"
              placeholder="Search destinations..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-accent outline-none"
            />

          </div>

        </form>

      </div>

      <!-- Table Card -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden">

        <!-- Table -->
        <div class="overflow-x-auto">

          <table class="w-full text-left">

            <thead class="bg-slate-50 dark:bg-slate-800/50">

              <tr class="text-slate-500 text-[11px] uppercase tracking-wider">

                <th class="px-6 py-4 font-bold">Destination</th>
                <th class="px-6 py-4 font-bold">District</th>
                <th class="px-6 py-4 font-bold">Category</th>
                <th class="px-6 py-4 font-bold">Rating</th>
                <th class="px-6 py-4 font-bold text-right">Actions</th>

              </tr>

            </thead>

            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">

              <% destinations.forEach(destination => { %>

              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">

                <!-- Destination -->
                <td class="px-6 py-4">

                  <div class="flex items-center gap-4">

                    <div class="w-16 h-12 rounded-lg overflow-hidden bg-slate-200 shrink-0">

                      <img
                        src="<%= destination.img %>"
                        alt="<%= destination.title %>"
                        class="w-full h-full object-cover"
                      />

                    </div>

                    <div>

                      <h4 class="font-semibold text-slate-900 dark:text-white">
                        <%= destination.title %>
                      </h4>

                      <p class="text-xs text-slate-500 mt-1 line-clamp-1">
                        <%= destination.desc %>
                      </p>

                    </div>

                  </div>

                </td>

                <!-- District -->
                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                  <%= destination.district %>
                </td>

                <!-- Category -->
                <td class="px-6 py-4">

                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 dark:bg-blue-900/20 dark:text-blue-400">
                    <%= destination.category %>
                  </span>

                </td>

                <!-- Rating -->
                <td class="px-6 py-4">

                  <div class="flex items-center gap-1 text-amber-500">

                    <span class="material-symbols-outlined text-[18px]">
                      star
                    </span>

                    <span class="text-sm font-semibold">
                      <%= destination.rating %>
                    </span>

                  </div>

                </td>

                <!-- Actions -->
                <td class="px-6 py-4">

                  <div class="flex justify-end gap-2">

                    <!-- Edit -->
                    <a
                      href="/admin/destinations/edit/<%= destination.id %>"
                      class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 hover:text-accent transition-all"
                    >
                      <span class="material-symbols-outlined">
                        edit
                      </span>
                    </a>

                    <!-- Delete -->
                    <a
                      href="/admin/destinations/delete/<%= destination.id %>"
                      onclick="return confirm('Delete this destination?')"
                      class="p-2 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/20 text-slate-500 hover:text-red-500 transition-all"
                    >
                      <span class="material-symbols-outlined">
                        delete
                      </span>
                    </a>

                  </div>

                </td>

              </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">

          <p class="text-sm text-slate-500">
            Total Destinations :
            <span class="font-bold text-primary dark:text-white">
              <%= destinations.length %>
            </span>
          </p>

        </div>

      </div>

    </main>

  </div>

</div>

</body>
</html>