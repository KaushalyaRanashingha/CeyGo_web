<header class="h-16 bg-white dark:bg-background-dark border-b border-slate-200 dark:border-slate-800 flex items-center justify-between px-8 shrink-0">
    <!-- Search bar -->
    <div class="flex items-center flex-1 max-w-md">
        <div class="relative w-full">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
            <input class="w-full bg-slate-100 dark:bg-slate-900 border-none rounded-xl py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-accent/50 transition-all"
                   placeholder="Search destinations, bookings, or users..." type="text"/>
        </div>
    </div>

    <!-- Notifications & Profile -->
    <div class="flex items-center gap-4">
        <!-- Notifications -->
        <button class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full relative">
            <span class="material-symbols-outlined">notifications</span>
            <span class="absolute top-2 right-2 size-2 bg-accent rounded-full border-2 border-white dark:border-background-dark"></span>
        </button>

        <div class="h-8 w-[1px] bg-slate-200 dark:bg-slate-700 mx-2"></div>

        <!-- Profile -->
        <div class="flex items-center gap-3 cursor-pointer group">
            <div class="text-right hidden sm:block">
                <p class="text-sm font-semibold leading-none text-slate-900 dark:text-slate-100">admin</p>
                <p class="text-[11px] text-slate-500 mt-1 uppercase">Super Admin</p>
            </div>
            <img alt="Admin Profile" class="size-10 rounded-full border-2 border-slate-100 dark:border-slate-800"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuDe8FYlUpKk2GvD1_dVJ0tkxKM4WDHIs90ZaD0dFDIRlniLhxdAVitQAmIYTp2VcXulQrSCtErhUcZmODkMKMfeECwFpS0GHOYZpwYGu-q14N4CoLm1xiD8fL5BAOpdS5oYaqkZrDL5jAlApJtmRzO4wz1giL8CglAbXUcoHTKbqGgRQN2XJpjsjoKO45xSwMUmYwQWWnyIcD7lmIX-6V6Nok44pSiE-hgNYiXVx9qBGbo2dkTy1jolB1RWdkiO03nC5OcKy7aUEfE"/>
        </div>
    </div>
</header>