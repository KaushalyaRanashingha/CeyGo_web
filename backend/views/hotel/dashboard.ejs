<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title><%= title %></title>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>

<style>
body {
    font-family: 'Public Sans', sans-serif;
    background-color: #F4F7FB;
}
.sidebar-item-active {
    background-color: rgba(255, 122, 0, 0.1);
    color: #FF7A00;
    border-right: 4px solid #FF7A00;
}
</style>
</head>

<body class="bg-background-light text-slate-900 font-display">

<div class="flex min-h-screen">

<!-- Sidebar -->
<aside class="w-64 bg-primary text-white hidden md:flex flex-col">

<div class="p-6">
<h1 class="text-lg font-bold">CeyGo</h1>
<p class="text-xs text-gray-400">Partner Portal</p>
</div>

<nav class="flex-1 px-4 space-y-2">

<a href="/dashboard" class="sidebar-item-active block p-3 rounded">Dashboard</a>

<a href="/hotels" class="block p-3 hover:bg-white/10 rounded">My Hotels</a>

<a href="/rooms" class="block p-3 hover:bg-white/10 rounded">Rooms</a>

<a href="/bookings" class="block p-3 hover:bg-white/10 rounded">Bookings</a>

<a href="/reviews" class="block p-3 hover:bg-white/10 rounded">Reviews</a>

<a href="/earnings" class="block p-3 hover:bg-white/10 rounded">Earnings</a>

</nav>

</aside>

<!-- Main -->
<main class="flex-1 p-6">

<!-- Header -->
<div class="flex justify-between items-center mb-6">

<h2 class="text-2xl font-bold">Dashboard</h2>

<div>
<p class="font-semibold"><%= user.hotelName %></p>
<p class="text-xs text-gray-500">Hotel Owner</p>
</div>

</div>

<!-- Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">

<div class="bg-white p-4 rounded shadow">
<p>Total Rooms</p>
<h3 class="text-2xl font-bold"><%= stats.totalRooms %></h3>
</div>

<div class="bg-white p-4 rounded shadow">
<p>Active Bookings</p>
<h3 class="text-2xl font-bold"><%= stats.activeBookings %></h3>
</div>

<div class="bg-white p-4 rounded shadow">
<p>Revenue</p>
<h3 class="text-2xl font-bold">$<%= stats.revenue %></h3>
</div>

</div>

<!-- Booking Table -->
<div class="mt-8 bg-white rounded shadow overflow-hidden">

<div class="p-4 border-b">
<h3 class="font-bold">Recent Bookings</h3>
</div>

<table class="w-full">

<thead class="bg-gray-100 text-left">
<tr>
<th class="p-3">Guest</th>
<th class="p-3">Room</th>
<th class="p-3">Check-in</th>
<th class="p-3">Check-out</th>
<th class="p-3">Status</th>
</tr>
</thead>

<tbody>

<% bookings.forEach(booking => { %>
<tr class="border-t">

<td class="p-3"><%= booking.name %></td>

<td class="p-3"><%= booking.room %></td>

<td class="p-3"><%= booking.checkIn %></td>

<td class="p-3"><%= booking.checkOut %></td>

<td class="p-3">
<span class="px-2 py-1 text-xs rounded 
<%= booking.status === 'PENDING' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700' %>">
<%= booking.status %>
</span>
</td>

</tr>
<% }) %>

</tbody>
</table>

</div>

</main>

</div>

</body>
</html>